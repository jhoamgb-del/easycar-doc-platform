# Public browser configuration
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Private server configuration - never expose these values in VITE_ variables
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# DocuSeal Cloud or self-hosted DocuSeal
DOCUSEAL_API_URL=https://api.docuseal.com
DOCUSEAL_API_KEY=YOUR_DOCUSEAL_API_KEY
DOCUSEAL_CUSTOMER_ROLE=Customer
DOCUSEAL_REPLY_TO=sales@easycarus.com
DOCUSEAL_BCC_COMPLETED=sales@easycarus.com
DOCUSEAL_SEND_SMS=true
DOCUSEAL_REQUIRE_PHONE_2FA=true
DOCUSEAL_REQUIRE_EMAIL_2FA=false
DOCUSEAL_COMPLETED_REDIRECT_URL=https://docs.easycarus.com/
DOCUSEAL_EXPIRE_DAYS=14
DOCUSEAL_WEBHOOK_SECRET=whsec_YOUR_DOCUSEAL_WEBHOOK_SECRET
